pipeline {
  agent any

environment {
    FRONTEND_IMAGE = "ketanops/frontend"
    BACKEND_IMAGE  = "ketanops/backend"
    IMAGE_TAG = "${BUILD_NUMBER}"
    DOCKER_CREDS = credentials('dockerhub-creds')
    SNYK_TOKEN = credentials('snyk-token')
    SONAR_TOKEN = credentials('sonar-token')
    SONAR_PROJECT_KEY = "ketankakde_DevSecOps"
    SONAR_ORG = "ketankakde"
}

stages {

    stage('Checkout') {
        steps {
            git branch: 'main',
                url: 'https://github.com/ketankakde/DevSecOps.git'
        }
    }

    stage('SonarCloud Scan') {
    steps {
        script {
            def scannerHome = tool 'sonar-scanner'

            sh """
            ${scannerHome}/bin/sonar-scanner \
            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
            -Dsonar.organization=${SONAR_ORG} \
            -Dsonar.host.url=https://sonarcloud.io \
            -Dsonar.token=${SONAR_TOKEN}
            """
        }
    }
}
    stage('Snyk Scan') {
    steps {
        withCredentials([string(credentialsId: 'snyk-token', variable: 'SNYK_TOKEN')]) {
            sh '''
            snyk auth ${SNYK_TOKEN}

            snyk test frontend \
            --severity-threshold=high

            snyk test backend \
            --severity-threshold=high

            snyk monitor frontend
            snyk monitor backend
            '''
        }
    }
}
    stage('Build Images') {
        steps {
            sh '''
            docker build -t ${FRONTEND_IMAGE}:${IMAGE_TAG} ./frontend
            docker build -t ${BACKEND_IMAGE}:${IMAGE_TAG} ./backend

            docker tag ${FRONTEND_IMAGE}:${IMAGE_TAG} ${FRONTEND_IMAGE}:latest
            docker tag ${BACKEND_IMAGE}:${IMAGE_TAG} ${BACKEND_IMAGE}:latest
            '''
        }
    }

    stage('Trivy Scan') {
        steps {
            sh '''
            trivy image \
            --severity HIGH,CRITICAL \
            --ignore-unfixed \
            --exit-code 1 \
            ${FRONTEND_IMAGE}:${IMAGE_TAG}

            trivy image \
            --severity HIGH,CRITICAL \
            --ignore-unfixed \
            --exit-code 1 \
            ${BACKEND_IMAGE}:${IMAGE_TAG}
            '''
        }
    }

    stage('Docker Login') {
        steps {
            sh '''
            echo ${DOCKER_CREDS_PSW} | docker login \
            -u ${DOCKER_CREDS_USR} \
            --password-stdin
            '''
        }
    }

    stage('Push Images') {
        steps {
            sh '''
            docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}
            docker push ${BACKEND_IMAGE}:${IMAGE_TAG}

            docker push ${FRONTEND_IMAGE}:latest
            docker push ${BACKEND_IMAGE}:latest
            '''
        }
    }

    stage('Deploy') {
        steps {
            sh '''
            docker compose pull

            docker compose down

            docker compose up -d
            '''
        }
    }

    stage('OWASP ZAP DAST') {
        steps {
            sh '''
            docker run --rm \
            ghcr.io/zaproxy/zaproxy:stable \
            zap-baseline.py \
            -t http://localhost
            '''
        }
    }
}

post {
    success {
        echo 'Pipeline Completed Successfully'
    }

    failure {
        echo 'Pipeline Failed'
    }
}

}
